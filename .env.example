# ── FairOrder Product App ──
# Copy this file to .env and fill in your values.
# For Docker: these are set in docker-compose.yml — no .env file needed.

# ── Database ──
DATABASE_URL="postgresql://fairorder:fairorder@localhost:5432/fairorder"

# ── Email Provider ──
# Options: "plunk" (Plunk ESP), "smtp" (any SMTP server), "console" (dev logging)
# Default: "console" in development, "plunk" in production
EMAIL_PROVIDER="console"

# Plunk (only if EMAIL_PROVIDER=plunk)
# PLUNK_API_KEY="your-plunk-api-key"

# SMTP (only if EMAIL_PROVIDER=smtp)
# SMTP_HOST="localhost"
# SMTP_PORT="1025"
# SMTP_USER=""
# SMTP_PASS=""
# SMTP_FROM="noreply@your-domain.com"

# ── URLs ──
# Base URL for magic link emails (where users click to verify)
MAGIC_LINK_BASE_URL="http://localhost:3000"

# Public-facing site URL (used for QR codes and external links)
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# Public-facing app URL (used in meta tags)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ── Image Storage ──
# Options: "minio" (local S3-compatible), "bunny" (Bunny.net CDN), "console" (dev logging)
# Default: "console" in development, "bunny" in production
# For Docker: defaults to "minio" — see docker-compose.yml
STORAGE_PROVIDER="console"

# MinIO (only if STORAGE_PROVIDER=minio — runs via docker-compose)
# MINIO_ENDPOINT="http://localhost:9000"
# MINIO_ACCESS_KEY="fairorder"
# MINIO_SECRET_KEY="fairorder"
# MINIO_BUCKET="fairorder-images"
# NEXT_PUBLIC_MINIO_URL="http://localhost:9000"

# Bunny.net (only if STORAGE_PROVIDER=bunny)
# BUNNY_STORAGE_API_KEY=""
# BUNNY_STORAGE_ZONE="fair-order-app"
# BUNNY_STORAGE_REGION="de"
# NEXT_PUBLIC_BUNNY_CDN_URL="https://cdn.fair-order.de"
